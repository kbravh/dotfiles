# Add local bin to path
export PATH="$PATH:/home/kbravh/.local/bin"

# Add Cargo bins to PATH
export PATH="$PATH:/home/kbravh/.cargo/bin"

# Add ~/bin to PATH
export PATH="$PATH:/home/kbravh/bin"

# Load secrets (API keys, &c.)
[[ -f /home/kbravh/.secrets ]] && source /home/kbravh/.secrets

# Set the default editor
export EDITOR=$(which nvim)

# Set the config home
export XDG_CONFIG_HOME="$HOME/.config"

# Set bat config home
export BAT_CONFIG_PATH="$XDG_CONFIG_HOME/bat/bat.conf"

# Add brew to path
eval "$(/home/linuxbrew/.linuxbrew/bin/brew shellenv bash)"

# Git Pager
export GIT_PAGER="delta"

# Claude settings
export CLAUDE_CODE_EXPERIMENTAL_AGENT_TEAMS="1"

# Android dev setup
export ANDROID_HOME=~/Android/Sdk
export JAVA_HOME=/usr/lib/jvm/java-26-openjdk
export PATH=$PATH:$ANDROID_HOME/platform-tools
